{
  "manifest_version": 3,
  "name": "SuperDev Pro — Web Developer Toolkit",
  "version": "1.0.0",
  "description": "Free all-in-one web dev toolkit: inspect & edit CSS, pick colors, swap fonts, export elements, measure, extract images, screenshot.",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      }
    },
    "toggle-sidebar": {
      "description": "Toggle SuperDev sidebar",
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}


